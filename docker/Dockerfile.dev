# OPA技术文档项目 - 开发环境Docker镜像

FROM node:18-alpine

# 安装常用工具
RUN apk add --no-cache \
    git \
    curl \
    bash \
    make

# 安装OPA
RUN curl -L -o /usr/local/bin/opa https://openpolicyagent.org/downloads/v1.4.0/opa_linux_amd64_static && \
    chmod 755 /usr/local/bin/opa

# 设置工作目录
WORKDIR /app

# 暴露端口
EXPOSE 8080

# 默认命令
CMD ["sh"]
